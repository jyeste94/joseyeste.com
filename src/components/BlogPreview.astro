---
import LinkButton from "./LinkButton.astro"
import SectionContainer from "./SectionContainer.astro"
import { getAllPosts } from "@/data/posts"

const posts = getAllPosts().slice(0, 3)

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString("es-ES", {
    day: "2-digit",
    month: "short",
    year: "numeric",
  })
---

<SectionContainer id="blog" class="py-12 md:py-20">
  <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-center">
    <div>
      <p class="text-sm uppercase tracking-[0.2rem] text-yellow-500 font-semibold">
        Blog
      </p>
      <h2 class="mt-2 text-3xl font-semibold text-gray-800 dark:text-white">
        Últimas notas de trabajo
      </h2>
      <p class="mt-2 text-base text-gray-600 dark:text-gray-300 max-w-2xl">
        Documentación rápida de cosas que me funcionan en el día a día.
        Backend, APIs y pequeños experimentos sin humo.
      </p>
    </div>
    <LinkButton href="/blog">Ver blog</LinkButton>
  </div>

  <div class="grid w-full gap-6 mt-10 md:grid-cols-2">
    {
      posts.map((post) => (
        <article class="group relative overflow-hidden rounded-2xl border border-gray-200 bg-white/70 p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-xl dark:border-gray-800 dark:bg-gray-900/70">
          <div class="flex items-center gap-3 text-sm text-gray-600 dark:text-gray-300">
            <span class="rounded-full bg-yellow-100 px-3 py-1 text-xs font-semibold text-yellow-800 dark:bg-yellow-900/60 dark:text-yellow-200">
              {post.category}
            </span>
            <span class="text-gray-500 dark:text-gray-400">{formatDate(post.date)}</span>
            <span class="text-gray-400">·</span>
            <span class="text-gray-500 dark:text-gray-400">{post.readingTime}</span>
          </div>
          <h3 class="mt-3 text-2xl font-semibold text-gray-900 transition group-hover:text-yellow-600 dark:text-white dark:group-hover:text-yellow-300">
            <a href={`/blog/${post.slug}`} class="inline-flex items-center gap-2">
              {post.title}
            </a>
          </h3>
          <p class="mt-3 text-base text-gray-700 dark:text-gray-200">
            {post.summary}
          </p>
          <ul class="mt-4 flex flex-wrap gap-2 text-xs text-gray-500 dark:text-gray-300">
            {post.tags.map((tag) => (
              <li class="rounded-full bg-gray-100 px-3 py-1 font-medium text-gray-700 dark:bg-gray-800 dark:text-gray-200">
                {tag}
              </li>
            ))}
          </ul>
          <a
            href={`/blog/${post.slug}`}
            class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-yellow-600 transition hover:gap-3 dark:text-yellow-200"
          >
            Leer artículo
            <span aria-hidden="true">→</span>
          </a>
        </article>
      ))
    }
  </div>
</SectionContainer>
