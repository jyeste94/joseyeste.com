---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/SectionContainer.astro";

import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString("es-ES", {
    day: "2-digit",
    month: "long",
    year: "numeric",
  });
---

<Layout
  title="Blog de Jose Yeste - Backend, APIs y ecommerce"
  description="Notas rápidas de trabajo sobre backend, APIs, ecommerce headless y productividad técnica."
>
  <main class="px-4">
    <SectionContainer id="blog" class="py-16 md:py-24 space-y-10">
      <div class="space-y-4">
        <p
          class="inline-flex rounded-full bg-yellow-100 px-4 py-1 text-xs font-semibold uppercase tracking-[0.25rem] text-yellow-800 dark:bg-yellow-900/50 dark:text-yellow-200"
        >
          Blog
        </p>
        <h1 class="text-4xl font-bold text-gray-900 dark:text-white">
          Apuntes técnicos sin relleno
        </h1>
        <p class="max-w-3xl text-lg text-gray-700 dark:text-gray-200">
          Documentación breve de cosas que aplico a diario: cómo despliego
          servicios, cómo documento APIs y qué patrones no fallan en ecommerce.
          Todo en español y con foco en ser práctico.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {
          posts.map((post) => (
            <article class="flex h-full flex-col justify-between rounded-2xl border border-gray-200 bg-white/70 p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-xl dark:border-gray-800 dark:bg-gray-900/60">
              <div class="space-y-3">
                <div class="flex flex-wrap items-center gap-3 text-sm text-gray-600 dark:text-gray-300">
                  <span class="rounded-full bg-gray-900 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-yellow-300 dark:bg-gray-100 dark:text-gray-900">
                    {post.data.category}
                  </span>
                  <span class="text-gray-500 dark:text-gray-400">
                    {formatDate(post.data.date.toString())}
                  </span>
                  <span class="text-gray-400">·</span>
                  <span class="text-gray-500 dark:text-gray-400">
                    {post.data.readingTime}
                  </span>
                </div>
                <h2 class="text-2xl font-semibold text-gray-900 transition hover:text-yellow-600 dark:text-white dark:hover:text-yellow-300">
                  <a
                    href={`/blog/${post.slug}`}
                    class="inline-flex items-center gap-2"
                  >
                    {post.data.title}
                  </a>
                </h2>
                <p class="text-base text-gray-700 dark:text-gray-200">
                  {post.data.summary}
                </p>
                <ul class="flex flex-wrap gap-2 text-xs text-gray-600 dark:text-gray-300">
                  {post.data.tags.map((tag) => (
                    <li class="rounded-full bg-gray-100 px-3 py-1 font-medium text-gray-700 dark:bg-gray-800 dark:text-gray-200">
                      {tag}
                    </li>
                  ))}
                </ul>
              </div>
              <a
                href={`/blog/${post.slug}`}
                class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-yellow-600 transition hover:gap-3 dark:text-yellow-200"
              >
                Leer artículo
                <span aria-hidden="true">→</span>
              </a>
            </article>
          ))
        }
      </div>
    </SectionContainer>
  </main>
</Layout>
